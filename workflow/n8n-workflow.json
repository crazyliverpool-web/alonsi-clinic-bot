\\u0e31\\u0e19 / \\u0e02\\u0e39\\u0e14\\u0e2b\\u0e34\\u0e19\\u0e1b\\u0e39\\u0e19\\n\\u0e40\\u0e21\\u0e37\\u0e48\\u0e2d\\u0e16\\u0e32\\u0e21\\u0e40\\u0e23\\u0e37\\u0e48\\u0e2d\\u0e07\\u0e19\\u0e35\\u0e49\\u0e44\\u0e21\\u0e48\\u0e27\\u0e48\\u0e32\\u0e08\\u0e30\\u0e16\\u0e32\\u0e21\\u0e2d\\u0e22\\u0e48\\u0e32\\u0e07\\u0e43\\u0e14\\u0e2d\\u0e22\\u0e48\\u0e32\\u0e07\\u0e2b\\u0e19\\u0e36\\u0e48\\u0e07 \\u0e43\\u0e2b\\u0e49\\u0e41\\u0e08\\u0e49\\u0e07\\u0e23\\u0e32\\u0e04\\u0e32\\u0e17\\u0e31\\u0e49\\u0e07 3 \\u0e1a\\u0e23\\u0e34\\u0e01\\u0e32\\u0e23\\u0e1e\\u0e23\\u0e49\\u0e2d\\u0e21\\u0e01\\u0e31\\u0e19\\u0e40\\u0e2a\\u0e21\\u0e2d:\\n- \\u0e2d\\u0e38\\u0e14\\u0e1f\\u0e31\\u0e19: 800-1,600 \\u0e1a\\u0e32\\u0e17\\n- \\u0e16\\u0e2d\\u0e19\\u0e1f\\u0e31\\u0e19: 600-1,200 \\u0e1a\\u0e32\\u0e17\\n- \\u0e02\\u0e39\\u0e14\\u0e2b\\u0e34\\u0e19\\u0e1b\\u0e39\\u0e19: 800-1,600 \\u0e1a\\u0e32\\u0e17\\n\\n### \\u0e23\\u0e31\\u0e01\\u0e29\\u0e32\\u0e23\\u0e32\\u0e01\\u0e1f\\u0e31\\u0e19 / \\u0e1c\\u0e48\\u0e32\\u0e1f\\u0e31\\u0e19\\u0e04\\u0e38\\u0e14\\n- \\u0e23\\u0e31\\u0e01\\u0e29\\u0e32\\u0e23\\u0e32\\u0e01\\u0e1f\\u0e31\\u0e19 (\\u0e40\\u0e23\\u0e34\\u0e48\\u0e21\\u0e15\\u0e49\\u0e19): \\u0e1f\\u0e31\\u0e19\\u0e2b\\u0e19\\u0e49\\u0e32 5,000 \\u0e1a\\u0e32\\u0e17 | \\u0e1f\\u0e31\\u0e19\\u0e01\\u0e23\\u0e32\\u0e21\\u0e19\\u0e49\\u0e2d\\u0e22 7,000 \\u0e1a\\u0e32\\u0e17 | \\u0e1f\\u0e31\\u0e19\\u0e01\\u0e23\\u0e32\\u0e21 12,000 \\u0e1a\\u0e32\\u0e17\\n- \\u0e1c\\u0e48\\u0e32\\u0e1f\\u0e31\\u0e19\\u0e04\\u0e38\\u0e14: 1,500-4,500 \\u0e1a\\u0e32\\u0e17\\n\\n### \\u0e08\\u0e31\\u0e14\\u0e1f\\u0e31\\u0e19\\n\\u0e08\\u0e31\\u0e14\\u0e1f\\u0e31\\u0e19\\u0e42\\u0e25\\u0e2b\\u0e30 (\\u0e42\\u0e2d\\u0e23\\u0e34\\u0e07) \\u0e21\\u0e35\\u0e04\\u0e48\\u0e32\\u0e43\\u0e0a\\u0e49\\u0e08\\u0e48\\u0e32\\u0e22 3 \\u0e2a\\u0e48\\u0e27\\u0e19\\u0e04\\u0e48\\u0e30\\n\\n\\u0e40\\u0e23\\u0e34\\u0e48\\u0e21\\u0e15\\u0e49\\u0e19\\n\\u2022 \\u0e1b\\u0e23\\u0e36\\u0e01\\u0e29\\u0e32\\u0e17\\u0e34\\u0e28\\u0e17\\u0e32\\u0e07\\u0e01\\u0e32\\u0e23\\u0e23\\u0e31\\u0e01\\u0e29\\u0e32 \\u2014 100 \\u0e1a\\u0e32\\u0e17\\n\\u2022 \\u0e1e\\u0e34\\u0e21\\u0e1e\\u0e4c\\u0e1f\\u0e31\\u0e19 + X-ray \\u2014 2,000 \\u0e1a\\u0e32\\u0e17\\n\\n\\u0e04\\u0e48\\u0e32\\u0e15\\u0e34\\u0e14\\u0e40\\u0e04\\u0e23\\u0e37\\u0e48\\u0e2d\\u0e07\\u0e21\\u0e37\\u0e2d (\\u0e40\\u0e25\\u0e37\\u0e2d\\u0e01\\u0e44\\u0e14\\u0e49)\\n1. \\u0e08\\u0e48\\u0e32\\u0e22\\u0e04\\u0e23\\u0e31\\u0e49\\u0e07\\u0e40\\u0e14\\u0e35\\u0e22\\u0e27: 10,000 \\u0e1a\\u0e32\\u0e17\\n2. \\u0e1c\\u0e48\\u0e2d\\u0e19 2 \\u0e07\\u0e27\\u0e14: 5,000 + 5,000 \\u0e1a\\u0e32\\u0e17\\n\\n\\u0e08\\u0e32\\u0e01\\u0e19\\u0e31\\u0e49\\u0e19 \\u0e04\\u0e48\\u0e32\\u0e1b\\u0e23\\u0e31\\u0e1a\\u0e23\\u0e32\\u0e22\\u0e40\\u0e14\\u0e37\\u0e2d\\u0e19 \\u2014 1,000 \\u0e1a\\u0e32\\u0e17/\\u0e40\\u0e14\\u0e37\\u0e2d\\u0e19\\n\\n\\u0e23\\u0e35\\u0e40\\u0e17\\u0e19\\u0e40\\u0e19\\u0e2d\\u0e23\\u0e4c (\\u0e2b\\u0e25\\u0e31\\u0e07\\u0e16\\u0e2d\\u0e14\\u0e40\\u0e04\\u0e23\\u0e37\\u0e48\\u0e2d\\u0e07\\u0e21\\u0e37\\u0e2d) \\u2014 5,000 \\u0e1a\\u0e32\\u0e17 (2 \\u0e0a\\u0e34\\u0e49\\u0e19)\\n\\n\\u0e23\\u0e30\\u0e22\\u0e30\\u0e40\\u0e27\\u0e25\\u0e32\\u0e23\\u0e31\\u0e01\\u0e29\\u0e32\\u0e02\\u0e36\\u0e49\\u0e19\\u0e2d\\u0e22\\u0e39\\u0e48\\u0e01\\u0e31\\u0e1a\\u0e41\\u0e15\\u0e48\\u0e25\\u0e30\\u0e40\\u0e04\\u0e2a\\u0e04\\u0e48\\u0e30 \\u0e41\\u0e19\\u0e30\\u0e19\\u0e33\\u0e19\\u0e31\\u0e14\\u0e1b\\u0e23\\u0e36\\u0e01\\u0e29\\u0e32\\u0e01\\u0e31\\u0e1a\\u0e2b\\u0e21\\u0e2d\\u0e01\\u0e48\\u0e2d\\u0e19\\u0e40\\u0e23\\u0e34\\u0e48\\u0e21\\u0e23\\u0e31\\u0e01\\u0e29\\u0e32\\u0e44\\u0e14\\u0e49\\u0e40\\u0e25\\u0e22\\u0e19\\u0e30\\u0e04\\u0e30\\n\\n### \\u0e23\\u0e32\\u0e01\\u0e1f\\u0e31\\u0e19\\u0e40\\u0e17\\u0e35\\u0e22\\u0e21 / \\u0e1f\\u0e31\\u0e19\\u0e1b\\u0e25\\u0e2d\\u0e21\\n- \\u0e23\\u0e32\\u0e01\\u0e1f\\u0e31\\u0e19\\u0e40\\u0e17\\u0e35\\u0e22\\u0e21: \\u0e40\\u0e23\\u0e34\\u0e48\\u0e21\\u0e15\\u0e49\\u0e19 35,000 \\u0e1a\\u0e32\\u0e17\\n- \\u