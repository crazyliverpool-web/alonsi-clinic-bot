    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst channelSecret = 'YOUR_LINE_CHANNEL_SECRET';\n\ntry {\n  const rawBody = $input.item.json.rawBody || JSON.stringify($input.item.json.body || $input.item.json);\n  const headers = $input.item.json.headers || {};\n  const signature = headers['x-line-signature'] || '';\n\n  if (signature) {\n    const hash = crypto.createHmac('sha256', channelSecret)\n      .update(rawBody, 'utf8')\n      .digest('base64');\n    if (hash !== signature) {\n      console.log('Signature mismatch — possible fake request or rawBody format issue');\n    }\n  }\n} catch(e) {\n  console.log('Signature check error:', e.message);\n}\n\nreturn $input.item;"
