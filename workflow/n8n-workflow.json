    {
      "parameters": {
        "jsCode": "const geminiBody = $input.item.json;\nconst text = geminiBody.candidates?.[0]?.content?.parts?.[0]?.text || '{}';\nlet parsed;\ntry { parsed = JSON.parse(text); } catch(e) {\n  parsed = { replyText: 'ขออภัยค่ะ เกิดข้อผิดพลาด กรุณาลองใหม่อีกครั้งค่ะ', booking_complete: false, appointment: null };\n}\nconst replyText = parsed.replyText || 'ขออภัยค่ะ เกิดข้อผิดพลาดค่ะ';\nconst booking_complete = parsed.booking_complete === true;\nconst appointment = parsed.appointment || null;\nconst prev = $('Build Gemini Request').item.json;\nconst newHistory = [...prev.history,\n  { role: 'user', parts: [{ text: prev.userMessage }] },\n  { role: 'model', parts: [{ text: replyText }] }\n].slice(-20);\nreturn [{ json: { replyText, booking_complete, appointment, userId: prev.userId, replyToken: prev.replyToken, newHistory: JSON.stringify(newHistory), row_number: prev.row_number } }];"
      },
